# ==================== API 配置 ====================
# OpenRouter API Key - 必填
# 从 https://openrouter.ai/keys 获取
OPENROUTER_API_KEY=your-openrouter-api-key-here

# ==================== 模型层级配置 ====================
# 可选: 覆盖默认的模型层级 (standard | high_quality | economy)
# OVERRUN_MODEL_TIER=standard

# ==================== 缓存配置 ====================
# 可选: 是否启用缓存 (true | false)
# ENABLE_CACHE=true

# ==================== 网络配置 ====================
# 可选: 如果使用代理，设置代理地址
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890

# ==================== Milvus 配置 ====================
# 可选: Milvus 服务器地址 (默认: http://localhost:19530)
# MILVUS_URI=http://localhost:19530
